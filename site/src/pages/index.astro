---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

// Lead piece — swap slug/title/standfirst here when the lead changes.
const lead = {
  slug: 'ai-adoption-gap',
  kicker: 'Data · This week\u2019s lead · Cartography',
  swatchClass: 'lead__swatch--data',
  headline: 'The United States makes the models. It ranks',
  highlight: '24th',
  headlineTail: ' at using them.',
  standfirst: 'Microsoft\u2019s 2025 survey of 32 economies puts the UAE first at 64%, Singapore at 61%, the United States at 28.3%.',
  author: 'Ollie Inkwell',
  date: '22 April 2026',
  readMinutes: 7,
  format: 'Interactive map',
  imageAlt: 'Lead piece — a world map of 2025 AI adoption rates across 32 economies, with the UAE leading.',
};
const leadImage = `/pieces/${lead.slug}/social/0.png`;
---
<BaseLayout siteSchema>
  <Masthead active="latest" />

  <main class="page">
    <!-- LEAD STORY -->
    <section class="lead">
      <div>
        <div class="lead__kicker rule-wobble-bottom">
          <span class="lead__swatch"></span>
          <span>{lead.kicker}</span>
        </div>
        <h1 class="lead__headline">
          <a href={`/pieces/${lead.slug}`} class="lead__link">
            {lead.headline} <span class="hl">{lead.highlight}</span>{lead.headlineTail}
          </a>
        </h1>
        <p class="lead__standfirst">
          {lead.standfirst}
        </p>
        <div class="lead__meta">
          <span>By <em>{lead.author}</em></span>
          <span class="dot">·</span>
          <span>{lead.date}</span>
          <span class="dot">·</span>
          <span>{lead.readMinutes} min read</span>
          <span class="dot">·</span>
          <span>{lead.format}</span>
        </div>
      </div>

      <a class="lead__visual" href={`/pieces/${lead.slug}`} aria-label={`Read: ${lead.highlight}${lead.headlineTail}`}>
        <img src={leadImage} alt={lead.imageAlt} loading="eager" />
      </a>
    </section>

    {/* Recent Curiosities section intentionally omitted until there are 4+ published pieces (current + 3 recent). */}

    <!-- EDITOR'S LETTER -->
    <section class="editor rule-wobble-top rule-wobble-bottom rule-wobble-bottom--heavy">
      <img
        class="editor__ollie"
        src="/assets/ollie-portrait-ink.png"
        alt="Prof. Ollie Inkwell, the common octopus who edits this publication."
      />
      <div class="editor__body">
        <h3 class="rule-wobble-bottom">From the desk</h3>
        <p class="editor__head">Two pieces a week, a year of them, and then we'll see.</p>
        <p class="editor__lede">
          Inkwell Review is an experiment. Every Tuesday and Friday we publish a chart that earns its space — a statistical peculiarity, properly sourced. No hot takes. No listicles.
        </p>
        <p class="editor__sig">Ollie</p>
        <p class="editor__role">Editor · Common octopus · Since issue 01</p>
      </div>
    </section>

    <!-- SUBSCRIBE STRIP -->
    <section class="sub" id="subscribe">
      <div>
        <p class="sub__kicker">Twice weekly · Free</p>
        <h4 class="sub__headline">
          Charts worth repeating <em>at dinner</em> — every Tuesday and Friday.
        </h4>
      </div>
      <div class="sub__actions">
        <a class="sub__cta" href="/rss.xml">
          <span>Subscribe via RSS</span>
          <span class="sub__cta-glyph" aria-hidden="true">›</span>
        </a>
        <p class="sub__pending">Email newsletter launching shortly.</p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px 40px;
  }

  /* ============================================================
     LEAD — two-column (text + stat card)
     ============================================================ */
  .lead {
    padding: 56px 0 40px;
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .lead__kicker {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding-bottom: 16px;
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 20px;
  }
  .lead__swatch {
    width: 14px;
    height: 14px;
    display: inline-block;
    background: var(--paper-blue);
    border: 1.5px solid var(--photocopy-black);
  }
  .lead__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(42px, 5.2vw, 72px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    text-wrap: balance;
  }
  .lead__link {
    color: inherit;
    text-decoration: none;
  }
  .lead__link:hover :global(.hl) {
    opacity: 0.88;
  }
  .lead__headline :global(.hl) {
    background: var(--photocopy-black);
    color: var(--photocopy-white);
    padding: 0 0.18em 0.08em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  .lead__standfirst {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 21px;
    line-height: 1.4;
    margin: 0 0 20px;
    max-width: 40em;
  }
  .lead__meta {
    display: flex;
    gap: 12px;
    align-items: baseline;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    flex-wrap: wrap;
  }
  .lead__meta em {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0;
    text-transform: none;
  }
  .lead__meta .dot {
    opacity: 0.45;
  }

  /* ---- Lead visual (piece social card as image) ---- */
  .lead__visual {
    display: block;
    position: relative;
    border: 1.5px solid var(--photocopy-black);
    background: var(--photocopy-white);
    overflow: hidden;
    line-height: 0;
    transition: opacity 0.15s ease;
  }
  .lead__visual img {
    display: block;
    width: 100%;
    height: auto;
  }
  .lead__visual:hover {
    opacity: 0.92;
  }

  /* ============================================================
     EDITOR'S LETTER
     ============================================================ */
  .editor {
    margin-top: 72px;
    padding: 48px 0 40px;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 48px;
    align-items: center;
  }
  .editor__ollie {
    display: block;
    width: 100%;
    height: auto;
  }
  .editor__body h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0 0 14px;
    padding-bottom: 14px;
  }
  .editor__head {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 40px;
    line-height: 1.02;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .editor__body p {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.58;
    margin: 0 0 12px;
    max-width: 56ch;
  }
  .editor__lede::first-letter {
    font-family: var(--font-display);
    font-weight: 800;
    float: left;
    font-size: 5.4em;
    line-height: 0.84;
    padding: 6px 12px 0 0;
    color: var(--photocopy-black);
  }
  .editor__sig {
    margin: 20px 0 2px;
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    line-height: 1;
  }
  .editor__sig::before {
    content: "— ";
    font-style: normal;
  }
  .editor__role {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.7;
    margin: 0;
  }

  /* ============================================================
     SUBSCRIBE STRIP
     ============================================================ */
  .sub {
    margin-top: 56px;
    padding: 28px 32px;
    background: var(--paper-purple);
    border: 1.5px solid var(--photocopy-black);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 32px;
    align-items: center;
  }
  .sub__kicker {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0 0 10px;
  }
  .sub__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
    text-wrap: balance;
  }
  .sub__headline em {
    font-family: var(--font-wordmark);
    font-weight: 400;
    font-size: 26px;
  }
  .sub__actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
  }
  .sub__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--photocopy-black);
    color: var(--paper-purple);
    border: 1.5px solid var(--photocopy-black);
    text-decoration: none;
    cursor: pointer;
  }
  .sub__cta:hover {
    background: var(--paper-purple);
    color: var(--photocopy-black);
  }
  .sub__cta-glyph {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    letter-spacing: 0;
    line-height: 1;
    transform: translateY(-1px);
  }
  .sub__pending {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 13px;
    margin: 0;
    opacity: 0.72;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 960px) {
    .lead {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .lead__visual {
      max-width: 520px;
      margin: 0 auto;
    }
    .editor {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .editor__ollie {
      max-width: 420px;
      margin: 0 auto;
    }
    .sub {
      grid-template-columns: 1fr;
    }
  }
</style>
