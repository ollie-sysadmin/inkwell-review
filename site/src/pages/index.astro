---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';
import CuriosityCard from '../components/CuriosityCard.astro';

const curiosities = [
  {
    category: 'data' as const,
    kicker: 'Data · Tue 21 Apr',
    headline: 'The country that builds AI ranks 24th at using it.',
    highlight: '24th',
    standfirst: 'Microsoft\u2019s global adoption survey puts the UAE at 64%, Singapore at 61%, France at 44%, and the United States at 28.3%.',
    author: 'Ollie Inkwell',
    readMinutes: 7,
    href: '/pieces/ai-adoption-gap',
  },
  {
    category: 'voice' as const,
    kicker: 'Voice · Fri 18 Apr',
    headline: 'The polite conspiracy of averages.',
    highlight: 'polite conspiracy',
    standfirst: 'Why the mean is lying to the city planners — and always was.',
    author: 'Ollie Inkwell',
    readMinutes: 5,
    href: '#',
  },
  {
    category: 'cities' as const,
    kicker: 'Cities · Tue 15 Apr',
    headline: "Where the world's commutes actually shrank.",
    highlight: 'actually shrank',
    standfirst: 'Fourteen OECD economies, ten years, one line that bends.',
    author: 'Rupa Das',
    readMinutes: 7,
    href: '#',
  },
  {
    category: 'archive' as const,
    kicker: 'Archive · Fri 11 Apr',
    headline: 'Chocolate bars, 1970 to now, weighed.',
    highlight: '1970 to now',
    standfirst: 'Fifty years of shrinkage, in grams and in confectionery.',
    author: 'Inkwell Review',
    readMinutes: 4,
    href: '#',
  },
  {
    category: 'cover' as const,
    kicker: 'Cover · Tue 08 Apr',
    headline: 'What the median human did yesterday.',
    highlight: 'did yesterday',
    standfirst: 'Twenty-four hours, seven billion overlapping schedules, one composite day.',
    author: 'Ollie Inkwell',
    readMinutes: 6,
    href: '#',
  },
  {
    category: 'interviews' as const,
    kicker: 'Interviews · Tue 01 Apr',
    headline: 'The city planner who keeps a spreadsheet of regrets.',
    highlight: 'spreadsheet of regrets',
    standfirst: "An interview on the uses of measuring what didn't happen.",
    author: 'Ollie Inkwell',
    readMinutes: 9,
    href: '#',
  },
];
---
<BaseLayout siteSchema>
  <Masthead active="latest" />

  <main class="page">
    <!-- LEAD STORY -->
    <section class="lead">
      <div>
        <div class="lead__kicker rule-wobble-bottom">
          <span class="lead__swatch"></span>
          <span>Data · This week's lead · Cartography</span>
        </div>
        <h1 class="lead__headline">
          <a href="/pieces/extradition-atlas" class="lead__link">
            The <span class="hl">78 countries</span> that will not send you home.
          </a>
        </h1>
        <p class="lead__standfirst">
          Every extradition treaty on Earth, mapped. One click toggles which country is doing the asking.
        </p>
        <div class="lead__meta">
          <span>By <em>Ollie Inkwell</em></span>
          <span class="dot">·</span>
          <span>19 April 2026</span>
          <span class="dot">·</span>
          <span>12 min read</span>
          <span class="dot">·</span>
          <span>Interactive map</span>
        </div>
      </div>

      <aside class="stat" aria-label="Lead story stat card">
        <div class="stat__kicker">
          <span>Data · Fig. I</span>
          <span>195 countries</span>
        </div>
        <div class="stat__fig">78</div>
        <p class="stat__caption">
          Countries that will <span class="hl">not</span> send you home to the United States.
        </p>
        <div class="stat__breakdown">
          <span>117 treaties</span><strong>·</strong><span>78 without</span>
        </div>
        <p class="stat__source">Source: US Department of State, 2024; Inkwell Review analysis.</p>
      </aside>
    </section>

    <!-- RECENT CURIOSITIES -->
    <section class="recent" id="recent">
      <div class="recent__head rule-wobble-bottom rule-wobble-bottom--double">
        <h2>Recent Curiosities</h2>
      </div>
      <div class="cards">
        {curiosities.map((c) => <CuriosityCard {...c} />)}
      </div>
    </section>

    <!-- EDITOR'S LETTER -->
    <section class="editor rule-wobble-top rule-wobble-bottom rule-wobble-bottom--heavy">
      <img
        class="editor__ollie"
        src="/assets/ollie-portrait-ink.png"
        alt="Prof. Ollie Inkwell, the common octopus who edits this publication."
      />
      <div class="editor__body">
        <h3 class="rule-wobble-bottom">From the desk</h3>
        <p class="editor__head">Two pieces a week, a year of them, and then we'll see.</p>
        <p class="editor__lede">
          Inkwell Review is an experiment. Every Tuesday and Friday we publish a chart that earns its space — a statistical peculiarity, properly sourced. No hot takes. No listicles.
        </p>
        <p class="editor__sig">Ollie</p>
        <p class="editor__role">Editor · Common octopus · Since issue 01</p>
      </div>
    </section>

    <!-- SUBSCRIBE STRIP -->
    <section class="sub" id="subscribe">
      <div>
        <p class="sub__kicker">Twice weekly · Free</p>
        <h4 class="sub__headline">
          Charts worth repeating <em>at dinner</em> — in your inbox Tuesday and Friday.
        </h4>
      </div>
      <form class="sub__form" action="https://newsletter.inkwellreview.com/subscribe" method="post">
        <input type="email" name="email" placeholder="reader@dinnerparty.club" aria-label="Email address" required />
        <button type="submit">Subscribe</button>
      </form>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px 40px;
  }

  /* ============================================================
     LEAD — two-column (text + stat card)
     ============================================================ */
  .lead {
    padding: 56px 0 40px;
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .lead__kicker {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding-bottom: 16px;
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 20px;
  }
  .lead__swatch {
    width: 14px;
    height: 14px;
    display: inline-block;
    background: var(--paper-blue);
    border: 1.5px solid var(--photocopy-black);
  }
  .lead__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(42px, 5.2vw, 72px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    text-wrap: balance;
  }
  .lead__link {
    color: inherit;
    text-decoration: none;
  }
  .lead__link:hover :global(.hl) {
    opacity: 0.88;
  }
  .lead__headline :global(.hl) {
    background: var(--photocopy-black);
    color: var(--photocopy-white);
    padding: 0 0.18em 0.08em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  .lead__standfirst {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 21px;
    line-height: 1.4;
    margin: 0 0 20px;
    max-width: 40em;
  }
  .lead__meta {
    display: flex;
    gap: 12px;
    align-items: baseline;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    flex-wrap: wrap;
  }
  .lead__meta em {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0;
    text-transform: none;
  }
  .lead__meta .dot {
    opacity: 0.45;
  }

  /* ---- Stat card ---- */
  .stat {
    background: var(--paper-blue);
    border: 1.5px solid var(--photocopy-black);
    padding: 24px 26px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
  }
  .stat__kicker {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    display: flex;
    justify-content: space-between;
    padding-bottom: 10px;
    border-bottom: 1.5px solid var(--photocopy-black);
    margin: 0;
  }
  .stat__fig {
    font-family: var(--font-wordmark);
    font-weight: 400;
    font-size: clamp(120px, 18vw, 200px);
    line-height: 0.86;
    letter-spacing: -0.04em;
    margin: 8px 0 0;
    color: var(--photocopy-black);
    font-variant-numeric: lining-nums;
  }
  .stat__caption {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    line-height: 1.2;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin: 0;
    max-width: 18ch;
  }
  .stat__caption :global(.hl) {
    background: var(--photocopy-black);
    color: var(--paper-blue);
    padding: 0 0.18em 0.08em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  .stat__breakdown {
    display: flex;
    gap: 14px;
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .stat__breakdown strong {
    font-family: var(--font-wordmark);
    font-weight: 400;
    font-style: italic;
    font-size: 14px;
  }
  .stat__source {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 12px;
    margin: 12px 0 0;
    padding-top: 10px;
    border-top: 1px solid #11111155;
    color: #111111cc;
  }

  /* ============================================================
     RECENT CURIOSITIES — six-card grid with tray-wash atmosphere
     ============================================================ */
  .recent {
    margin-top: 56px;
    position: relative;
  }
  .recent::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    background-image: url('/assets/masthead-tray-ink.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% auto;
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  .recent > * {
    position: relative;
    z-index: 1;
  }
  .recent__head {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding-bottom: 18px;
    margin-bottom: 22px;
  }
  .recent__head h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 32px;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ============================================================
     EDITOR'S LETTER
     ============================================================ */
  .editor {
    margin-top: 72px;
    padding: 48px 0 40px;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 48px;
    align-items: center;
  }
  .editor__ollie {
    display: block;
    width: 100%;
    height: auto;
  }
  .editor__body h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0 0 14px;
    padding-bottom: 14px;
  }
  .editor__head {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 40px;
    line-height: 1.02;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .editor__body p {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.58;
    margin: 0 0 12px;
    max-width: 56ch;
  }
  .editor__lede::first-letter {
    font-family: var(--font-display);
    font-weight: 800;
    float: left;
    font-size: 5.4em;
    line-height: 0.84;
    padding: 6px 12px 0 0;
    color: var(--photocopy-black);
  }
  .editor__sig {
    margin: 20px 0 2px;
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    line-height: 1;
  }
  .editor__sig::before {
    content: "— ";
    font-style: normal;
  }
  .editor__role {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.7;
    margin: 0;
  }

  /* ============================================================
     SUBSCRIBE STRIP
     ============================================================ */
  .sub {
    margin-top: 56px;
    padding: 28px 32px;
    background: var(--paper-purple);
    border: 1.5px solid var(--photocopy-black);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 32px;
    align-items: center;
  }
  .sub__kicker {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0 0 10px;
  }
  .sub__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
    text-wrap: balance;
  }
  .sub__headline em {
    font-family: var(--font-wordmark);
    font-weight: 400;
    font-size: 26px;
  }
  .sub__form {
    display: flex;
    gap: 0;
  }
  .sub__form input {
    flex: 1;
    padding: 12px 14px;
    font-family: var(--font-body);
    font-size: 15px;
    background: var(--photocopy-white);
    border: 1.5px solid var(--photocopy-black);
    border-right: 0;
    outline: none;
  }
  .sub__form input:focus {
    background: var(--paper-yellow);
  }
  .sub__form button {
    padding: 12px 22px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--photocopy-black);
    color: var(--paper-purple);
    border: 1.5px solid var(--photocopy-black);
    cursor: pointer;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 960px) {
    .lead {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .cards {
      grid-template-columns: 1fr 1fr;
    }
    .editor {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .editor__ollie {
      max-width: 420px;
      margin: 0 auto;
    }
    .sub {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .cards {
      grid-template-columns: 1fr;
    }
    .stat__fig {
      font-size: 120px;
    }
  }
</style>
