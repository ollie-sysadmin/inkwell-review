---
/**
 * Preview route for the 180×180 Apple home-screen icon.
 * Screenshotted to site/public/apple-touch-icon.png by
 * `scripts/export-brand-assets.mjs`.
 *
 * Matches the typographic "I" in site/public/favicon.svg — DM Serif
 * Display with a paper-purple misregistration shadow, centred on cream.
 */
import '../../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=180, initial-scale=1" />
    <title>Inkwell Review — apple-touch-icon (preview)</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body>
    <div class="icon" id="apple-touch-icon" aria-label="Inkwell Review">
      <span class="i-shadow" aria-hidden="true">I</span>
      <span class="i-ink">I</span>
    </div>

    <style>
      html, body { margin: 0; padding: 0; background: #222; }
      body::before, body::after { display: none !important; }

      .icon {
        position: relative;
        width: 180px;
        height: 180px;
        background: #E1E1E1;
        font-family: "DM Serif Display", "Times New Roman", Georgia, serif;
        font-weight: 400;
        font-size: 172px;
        line-height: 1;
      }
      .i-shadow, .i-ink {
        position: absolute;
        left: 0; right: 0;
        text-align: center;
      }
      .i-shadow {
        color: #CDA5EF;
        top: 8px;
        transform: translateX(4px);
      }
      .i-ink {
        color: #111111;
        top: 4px;
      }
    </style>
  </body>
</html>
