    font-size: 14px;
    letter-spacing: 0;
    text-transform: none;
  }
  .ah__meta .dot {
    opacity: 0.45;
  }

  /* ============================================================
     CONTROLS — outside the plate. Functional UI, not ornament.
     ============================================================ */
  .controls {
    display: flex;
