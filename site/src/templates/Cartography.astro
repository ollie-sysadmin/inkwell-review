  }
  :global(.chip:hover),
  :global(.chip.is-active) {
    background: var(--photocopy-black);
    color: var(--photocopy-white);
  }

  :global(.toggle) {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 1.5px solid var(--photocopy-black);
    padding: 7px 12px 8px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--photocopy-black);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  :global(.toggle__dot) {
    width: 10px;
    height: 10px;
    border: 1.5px solid var(--photocopy-black);
    background: transparent;
    display: inline-block;
  }
  :global(.toggle:hover),
  :global(.toggle.is-active) {
    background: var(--photocopy-black);
    color: var(--photocopy-white);
  }
  :global(.toggle:hover .toggle__dot),
  :global(.toggle.is-active .toggle__dot) {
    background: var(--photocopy-white);
    border-color: var(--photocopy-white);
  }

  /* ============================================================
     THE PLATE
     ============================================================ */
  .plate {
    position: relative;
    border: 1.5px solid var(--photocopy-black);
    background: var(--photocopy-white);
    padding: 28px 30px 26px;
    margin: 0 0 48px;
  }

  /* Cartouche — top-left overhang, white bg masks the frame behind. */
  .plate__cartouche {
    position: absolute;
    top: -1.5px;
    left: 24px;
    background: var(--photocopy-white);
    padding: 0 12px 0 8px;
    transform: translateY(-52%);
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .plate__fig {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--photocopy-black);
    border-right: 1.5px solid var(--photocopy-black);
    padding-right: 10px;
  }
  .plate__title {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    letter-spacing: -0.01em;
    color: var(--photocopy-black);
  }

  /* Per-piece stamp — top-right overhang, ink-jittered. Slot content
     should be an inline <svg> around 30×22. */
  .plate__stamp {
    position: absolute;
    top: -1.5px;
    right: 24px;
    background: var(--photocopy-white);
    padding: 6px 10px;
    transform: translateY(-45%);
  }
  .plate__stamp :global(svg) {
    display: block;
    width: 30px;
    height: 22px;
    filter: url(#ink-jitter);
  }

  /* Wobble rules — top and bottom (inside the plate). */
  .plate__rule {
    height: 12px;
    background-image:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 6' preserveAspectRatio='none'><path d='M0 3 Q 75 1.4 150 3 T 300 3 T 450 3 T 600 3' stroke='%23111111' stroke-width='2.4' fill='none' stroke-linecap='round'/></svg>");
    background-size: 600px 6px;
    background-repeat: repeat-x;
    background-position: center;
    margin: 6px 0 18px;
  }
  .plate__rule--bottom {
    margin: 26px 0 18px;
  }

  /* ---- Body: map left, intro right ---- */
  .plate__body {
    display: grid;
    grid-template-columns: 2.15fr 1fr;
    gap: 28px;
  }
  .plate__intro :global(p) {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 12px;
  }
  .plate__intro :global(p:first-of-type::first-letter) {
    font-family: var(--font-display);
    font-weight: 800;
    float: left;
    font-size: 3.6em;
    line-height: 0.82;
    padding: 4px 8px 0 0;
  }
  .plate__intro :global(strong) {
    font-family: var(--font-display);
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  /* ---- Map (Variant A — locked Session 5, 21 April 2026) ----
     The plate is dark across every desk. Two ink tones in play:
     the OCEAN (chart-card background) is a slight charcoal lift
     above pure ink, and NO-RECORD countries are pure ink-black.
     Just enough contrast between the two to keep the lattice of
     country borders readable inside the no-record mass — and to
     let the photocopy-white anchor still pop. The desk colour
     stays in the chrome only (kicker swatch, masthead, headline
     marks, misregistration shadow on the stat strip). */
  .map-wrap {
    position: relative;
    background: #1F1F1F; /* ocean — charcoal, lifted slightly above no-record ink */
    border: 1.5px solid var(--photocopy-black);
    overflow: hidden;
  }
  .map-wrap :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    cursor: grab;
  }
  .map-wrap :global(svg:active) {
    cursor: grabbing;
  }
  /* Ink-jitter on the path group — keeps the tooltip crisp because
     it lives outside the SVG. */
  .map-wrap :global(svg > g.country-group) {
    filter: url(#ink-jitter);
  }
  .map-wrap :global(.country) {
    /* Default = no-record / no-treaty: pure ink fill, white lattice
       border at higher opacity than before so the country grid is
       readable inside the no-record ink mass (Africa, Russia, etc.). */
    fill: var(--photocopy-black);
    stroke: var(--photocopy-white);
    stroke-width: 0.6;
    stroke-opacity: 0.7;
    transition: stroke-opacity 0.15s ease, stroke-width 0.15s ease;
    cursor: pointer;
  }
  .map-wrap :global(.country:hover) {
    stroke-opacity: 1;
    stroke-width: 1.2;
  }
  .map-wrap :global(.country--treaty)    { fill: var(--paper-green);  stroke-opacity: 0.8; }
  .map-wrap :global(.country--reluctant) { fill: var(--paper-yellow); stroke-opacity: 0.8; }
  .map-wrap :global(.country--haven)     { fill: var(--paper-pink);   stroke-opacity: 0.8; }
  .map-wrap :global(.country--suspended) { fill: var(--paper-brown);  stroke-opacity: 0.8; }
  .map-wrap :global(.country--eu-bloc)   { fill: var(--paper-purple); stroke-opacity: 0.8; }
  .map-wrap :global(.country--no-treaty) { fill: var(--photocopy-black); }
  .map-wrap :global(.country--anchor) {
    fill: var(--photocopy-white);
    stroke: var(--photocopy-black);
    stroke-opacity: 1;
    stroke-width: 1;
  }
  :global(.map-error) {
