    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  :global(.chip) {
    background: transparent;
    border: 1.5px solid var(--photocopy-black);
