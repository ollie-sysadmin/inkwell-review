  :global(.legend__sw--anchor)    { background: var(--photocopy-white); }
  :global(.legend__sw--treaty)    { background: var(--paper-green); }
  :global(.legend__sw--reluctant) { background: var(--paper-yellow); }
  :global(.legend__sw--haven)     { background: var(--paper-pink); }
  :global(.legend__sw--suspended) { background: var(--paper-brown); }
  :global(.legend__sw--eu-bloc)   { background: var(--paper-purple); }
  :global(.legend__sw--no-treaty) { background: var(--photocopy-black); }
  :global(.legend__name) {
