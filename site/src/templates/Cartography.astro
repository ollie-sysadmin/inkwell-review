    font-family: var(--font-wordmark);
    font-style: italic;
    font-size: 13px;
    color: var(--fg-muted);
  }

  /* ---- Stats strip with misregistration ---- */
  :global(.stats) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-top: 24px;
  }
  :global(.stat) {
    border: 1.5px solid var(--photocopy-black);
    padding: 14px 16px 12px;
    background: var(--photocopy-white);
  }
  :global(.stat__label) {
