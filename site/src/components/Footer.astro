---
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="foot__inner">
    <div class="foot__cols">
      <div class="foot__brand">
        <h5>Inkwell Review</h5>
        <p>Statistical peculiarities of human behaviour, charted properly and argued well. A twice-weekly publication edited by Prof. Ollie Inkwell.</p>
        <p class="cc">© {year} Inkwell Review · Vol. I</p>
      </div>

      <div class="foot__col">
        <h5>About</h5>
        <a href="/about/ollie">Ollie</a>
        <a href="/about/methodology">Methodology</a>
        <a href="/about/press">Press</a>
        <a href="/brand">Brand</a>
      </div>

      <div class="foot__col">
        <h5>Legal</h5>
        <a href="/legal/terms">Terms</a>
        <a href="/legal/privacy">Privacy</a>
        <a href="/sources">Sources</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="foot__col">
        <h5>Read</h5>
        <a href="/">Latest</a>
        <a href="/archive">Archive</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://newsletter.inkwellreview.com" rel="noopener">Substack</a>
      </div>
    </div>

    <div class="foot__bar">
      <span>inkwellreview.com · twice weekly</span>
      <div class="foot__social" aria-label="Follow">
        <a href="#" aria-label="Instagram">IG</a>
        <a href="#" aria-label="X">X</a>
        <a href="#" aria-label="LinkedIn">in</a>
        <a href="#" aria-label="Bluesky">Bs</a>
        <a href="#" aria-label="Threads">Th</a>
        <a href="/rss.xml" aria-label="RSS">RSS</a>
      </div>
      <span class="r">Set in Atkinson Hyperlegible Soft &amp; DM Serif Display.</span>
    </div>
  </div>
</footer>

<style>
  .foot {
    position: relative;
    margin-top: 0;
    padding: 80px 40px 28px;
    background: var(--photocopy-black);
    color: var(--desk);
  }
  .foot__inner {
    max-width: 1180px;
    margin: 0 auto;
  }
  .foot__cols {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 56px;
  }
  .foot__brand h5 {
    font-family: var(--font-wordmark);
    font-weight: 400;
    font-style: italic;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    color: var(--desk);
  }
  .foot__brand p {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    max-width: 32ch;
    margin: 0 0 16px;
    color: var(--desk);
    opacity: 0.82;
  }
  .foot__brand .cc {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    opacity: 0.6;
  }
  .foot__col h5 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 16px;
    color: var(--desk);
  }
  .foot__col a {
    display: block;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 2;
    color: var(--desk);
    text-decoration: none;
    opacity: 0.88;
  }
  .foot__col a:hover {
    text-decoration: underline;
    opacity: 1;
  }
  .foot__bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 32px;
    margin-top: 32px;
    padding-top: 18px;
    border-top: 1.5px solid var(--desk);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    opacity: 0.9;
    flex-wrap: wrap;
  }
  .foot__bar .r {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-size: 14px;
    letter-spacing: 0;
  }
  .foot__social {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .foot__social a {
    width: 28px;
    height: 28px;
    border: 1.5px solid var(--desk);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--desk);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0;
    opacity: 0.88;
  }
  .foot__social a:hover {
    background: var(--desk);
    color: var(--photocopy-black);
  }

  @media (max-width: 960px) {
    .foot__cols {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 640px) {
    .foot__cols {
      grid-template-columns: 1fr;
    }
  }
</style>
