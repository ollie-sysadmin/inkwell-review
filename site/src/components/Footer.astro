<style>
  .foot {
    position: relative;
    margin-top: 0;
    padding: 80px 40px 28px;
    background: var(--photocopy-black);
    color: var(--desk);
  }
  .foot__inner {
    max-width: 1180px;
    margin: 0 auto;
  }
  .foot__cols {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 56px;
  }
  .foot__brand h5 {
    font-family: var(--font-wordmark);
    font-weight: 400;
    font-style: italic;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    color: var(--desk);
  }
  .foot__brand p {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    max-width: 32ch;
    margin: 0 0 16px;
    color: var(--desk);
    opacity: 0.82;
  }
  .foot__brand .cc {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    opacity: 0.6;
  }
  .foot__col h5 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 16px;
    color: var(--desk);
  }
  .foot__col a {
    display: block;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 2;
    color: var(--desk);
    text-decoration: none;
    opacity: 0.88;
  }
  .foot__col a:hover {
    text-decoration: underline;
    opacity: 1;
  }
  .foot__bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 32px;
    margin-top: 32px;
    padding-top: 18px;
    border-top: 1.5px solid var(--desk);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    opacity: 0.9;
    flex-wrap: wrap;
  }
  .foot__bar .r {
    font-family: var(--font-wordmark);
    font-style: italic;
    font-size: 14px;
    letter-spacing: 0;
  }
  .foot__social {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .foot__social a {
    width: 32px;
    height: 32px;
    border: 1.5px solid var(--desk);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--desk);
    text-decoration: none;
    opacity: 0.88;
    transition: background 0.15s ease, color 0.15s ease, opacity 0.15s ease;
  }
  .foot__social a svg {
    width: 15px;
    height: 15px;
    display: block;
  }
  .foot__social a:hover {
    background: var(--desk);
    color: var(--photocopy-black);
    opacity: 1;
  }

  @media (max-width: 960px) {
    .foot {
      padding: 56px 28px 24px;
    }
    .foot__cols {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 28px;
      padding-bottom: 36px;
    }
    .foot__brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .foot__cols {
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }
    .foot__bar {
      gap: 18px;
    }
  }
</style>
